# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude (Anthropic API)
ANTHROPIC_API_KEY=
# Optional: model id (default: claude-sonnet-4-6). Override if needed.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Cron (Vercel) – set in Vercel dashboard; use CRON_SECRET to secure cron route
CRON_SECRET=

# Timezone for "today" and daily run (e.g. America/New_York)
# Use APP_TIMEZONE instead of TZ (TZ is reserved on Vercel).
APP_TIMEZONE=America/New_York

# Daily email digest (Resend: https://resend.com — verify domain or use onboarding@resend.dev for tests)
RESEND_API_KEY=
EMAIL_DIGEST_FROM="AI News <onboarding@resend.dev>"
EMAIL_DIGEST_TO=you@example.com
# Optional: absolute site URL for dashboard links in the email (defaults to https://VERCEL_URL on Vercel)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
