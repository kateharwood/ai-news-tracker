# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude (Anthropic API)
ANTHROPIC_API_KEY=
# Optional: model id (default: claude-sonnet-4-6). Override if needed.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Cron (Vercel) – set in Vercel dashboard; use CRON_SECRET to secure cron route
CRON_SECRET=

# Timezone for "today" and daily run (e.g. America/New_York)
TZ=America/New_York
